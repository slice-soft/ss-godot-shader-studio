[configuration]
entry_symbol = "ss_godot_shader_studio_init"
compatibility_minimum = "4.4"

[libraries]
; Editor / headless (debug build)
macos.debug                      = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.macos.template_debug.universal.dylib"
linux.debug.x86_64               = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.linux.template_debug.x86_64.so"
windows.debug.x86_64             = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.windows.template_debug.x86_64.dll"

; Exported templates — debug
macos.template_debug.universal   = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.macos.template_debug.universal.dylib"
linux.template_debug.x86_64      = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.linux.template_debug.x86_64.so"
windows.template_debug.x86_64    = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.windows.template_debug.x86_64.dll"

; Exported templates — release
macos.template_release.universal = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.macos.template_release.universal.dylib"
linux.template_release.x86_64    = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.linux.template_release.x86_64.so"
windows.template_release.x86_64  = "res://addons/ss_godot_shader_studio/gdextension/bin/libss_godot_shader_studio.windows.template_release.x86_64.dll"
